                        {
                            "name": "Sign In",
                            "event": [
                                {
                                    "listen": "test",
                                    "script": {
                                        "exec": [
                                            "var jsonData = pm.response.json();",
                                            "if (jsonData && jsonData.data && jsonData.data.token) {",
                                            "    pm.environment.set('authToken', jsonData.data.token);",
                                            "}"
                                        ],
                                        "type": "text/javascript"
                                    }
                                }
                            ],
                            "request": {
                                "method": "POST",
                                "header": [
